	</subDataset>
	<parameter name="ID" class="java.lang.String"/>
	<parameter name="timeID" class="java.lang.String"/>
	<queryString language="SQL">
		<![CDATA[SELECT time_table_automation.timetbltable.`programName`,
	time_table_automation.timetbltable.season,
	time_table_automation.timetbltable.`programID`,
	time_table_automation.alllabtimetable.`programID`,
	time_table_automation.alllabtimetable.`ROOMNAME`,
	time_table_automation.alllabtimetable.`ROOMID`
FROM time_table_automation.alllabtimetable
	INNER JOIN time_table_automation.timetbltable ON 
	 time_table_automation.timetbltable.`programID` = time_table_automation.alllabtimetable.`programID` 
WHERE 
	 time_table_automation.alllabtimetable.`ROOMID` = '$P!{timeID}' 
	 AND time_table_automation.timetbltable.`programID` = '$P!{ID}' 
	 AND time_table_automation.alllabtimetable.`ROOMID` IS NOT NULL  
LIMIT 1]]>
	</queryString>
