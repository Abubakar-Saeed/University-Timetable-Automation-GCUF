		<property name="com.jaspersoft.studio.data.defaultdataadapter" value="DataAdapter.xml"/>
		<property name="com.jaspersoft.studio.property.dataset.dialog.DatasetDialog.sash.w1" value="624"/>
		<property name="com.jaspersoft.studio.property.dataset.dialog.DatasetDialog.sash.w2" value="365"/>
		<parameter name="semesterTimeID" class="java.lang.String"/>
		<parameter name="semesterID" class="java.lang.String"/>
		<queryString language="SQL">
			<![CDATA[SELECT time_table_automation.alllabtimetable.`TIME`,
	time_table_automation.alllabtimetable.`MONDAY`,
	time_table_automation.alllabtimetable.`TUESDAY`,
	time_table_automation.alllabtimetable.`WEDNESDAY`,
	time_table_automation.alllabtimetable.`THURSDAY`,
	time_table_automation.alllabtimetable.`FRIDAY`,
	time_table_automation.alllabtimetable.`programID`,
	time_table_automation.alllabtimetable.`ROOMID`
FROM time_table_automation.alllabtimetable
WHERE 
	 time_table_automation.alllabtimetable.`ROOMID` = '$P!{semesterTimeID}' 
	 AND time_table_automation.alllabtimetable.`programID` = '$P!{semesterID}' 
	 AND time_table_automation.alllabtimetable.`ROOMID` IS NOT NULL]]>
		</queryString>
